modules = ["nodejs-20"]

# This forces Replit to run ONLY the frontend dashboard on your working port
run = "cd artifacts/artifacts/admin-dashboard && npm run dev -- --host 0.0.0.0 --port 8080"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081
